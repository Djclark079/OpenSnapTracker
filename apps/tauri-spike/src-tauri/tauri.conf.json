{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSnapTracker Tauri Spike",
  "version": "0.1.0",
  "identifier": "dev.opensnaptracker.tauri-spike",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "targets": ["appimage"],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
